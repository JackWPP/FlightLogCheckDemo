# Copy to .env and fill locally. Do not commit real API keys.
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Qwen/Qwen3.6-27B
CLEANER_MODEL=deepseek-ai/DeepSeek-V4-Flash
CLEANER_REQUEST_TIMEOUT_SECONDS=75
CLEANER_CONNECT_TIMEOUT_SECONDS=10
CLEANER_SECTION_TIMEOUT_SECONDS=75
CLEANER_TOTAL_BUDGET_SECONDS=90
CLEANER_SECTION_CONCURRENCY=3
CLEANER_TIMEOUT_CACHE_TTL_SECONDS=1800
ISSUE_DISPLAY_LIMIT=4
ISSUE_TRIAGE_TIMEOUT_SECONDS=45
ISSUE_TRIAGE_SKIP_ON_CLEANER_ERROR=1
ROI_REVIEW_PROVIDER=aliyun
ROI_REVIEW_MODEL=qwen3.5-ocr
ROI_REVIEW_FALLBACK_MODEL=qwen3.5-ocr
ROI_REVIEW_CONCURRENCY=3
ROI_REVIEW_MAX_FIELDS=12
ROI_REVIEW_CACHE_ENABLED=1
VLM_REQUEST_TIMEOUT_SECONDS=45
VLM_IMAGE_MAX_SIDE=900

ALIYUN_API_KEY=
ALIYUN_BASE_URL=https://llm-qcfwflkh57p80u70.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
ALIYUN_MODEL=qwen3.5-ocr

DEFAULT_PROVIDER=mock
REGISTRATION_MODE=off



# PaddleOCR AI Studio async OCR jobs
PADDLEOCR_AISTUDIO_TOKEN=
PPOCR_CACHE_ENABLED=1
PPOCR_POLL_INTERVAL_SECONDS=5
PPOCR_MAX_WAIT_SECONDS=300
